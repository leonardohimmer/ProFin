// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String   @default("OPERATOR") // ADMIN, MANAGER, OPERATOR
  password  String   // Hashed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts  Account[]
  categories Category[]
  cards     Card[]
  budgets   Budget[]
  goals     Goal[]
  investments Investment[]
}


model Account {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  // We don't store balance here to enforce append-only ledger architecture!
  // Balance is calculated from LedgerEntries
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries   LedgerEntry[]
}

model Transaction {
  id              String   @id @default(cuid())
  idempotencyKey  String?  @unique
  description     String
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])
  categoryName    String    @default("OUTROS") // Fallback
  contact         String?
  paymentType     String   @default("A VISTA")
  paymentMethod   String   @default("INDEFINIDO")
  isPaid          Boolean  @default(true)
  status          String   @default("COMPLETED")
  createdAt       DateTime @default(now())

  entries         LedgerEntry[]
}

model Category {
  id        String     @id @default(cuid())
  name      String
  parentId  String?
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  
  transactions Transaction[]

  @@unique([name, userId, parentId])
}




model LedgerEntry {
  id            String   @id @default(cuid())
  accountId     String
  account       Account  @relation(fields: [accountId], references: [id])
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  
  // Stored in cents to avoid floating point issues (e.g. 1000 = $10.00)
  amount        Int
  type          String   // CREDIT or DEBIT
  
  createdAt     DateTime @default(now())

  @@index([accountId])
  @@index([transactionId])
}

model Card {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  name            String   // e.g. "Premium Visa", "Business Elite"
  type            String   // e.g. "CREDIT", "DEBIT"
  cardNumber      String   // e.g. "•••• •••• •••• 4829"
  expirationDate  String   // e.g. "08/28"
  holderName      String   // e.g. "ALEX SILVA"
  limit           Int      // in cents
  currentInvoice  Int      // in cents
  dueDate         String   // e.g. "15 Out"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Budget {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  categoryName  String   // e.g. "Alimentação", "Lazer", "Transporte", "Moradia"
  targetAmount  Int      // in cents
  spentAmount   Int      // in cents
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Goal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  name          String    // e.g. "Reserva de Emergência", "Viagem"
  targetAmount  Int       // in cents
  currentAmount Int       // in cents
  deadline      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Investment {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  name          String   // e.g. "Tesouro Selic 2029", "PETR4", "Bitcoin"
  type          String   // e.g. "RENDA_FIXA", "ACOES", "FII", "CRIPTOMOEDAS"
  purchaseValue Int      // in cents (historical cost)
  currentValue  Int      // in cents (market value)
  quantity      Float    @default(1.0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
